{
  "name": "3d-model-viewer-pro",
  "version": "1.0.0",
  "description": "Professional 3D model viewer with advanced controls, animations, and real-time rendering",
  "main": "script.js",
  "scripts": {
    "build": "webpack --mode development",
    "build:production": "webpack --mode production",
    "build:analyze": "webpack --mode production --analyze",
    "start": "npm run build && serve dist",
    "start:dev": "webpack serve --mode development --open",
    "serve": "serve dist",
    "test": "npm run test:quality && npm run test:unit && npm run test:comprehensive",
    "test:enhanced": "node test/enhanced-test-runner.js",
    "test:unit": "karma start --single-run --reporters=progress",
    "test:comprehensive": "karma start karma.comprehensive.conf.js --single-run",
    "test:integration": "karma start karma.integration.conf.js --single-run",
    "test:performance": "karma start karma.performance.conf.js --single-run",
    "test:browser-compatibility": "karma start karma.browser-compatibility.conf.js --single-run",
    "test:all-comprehensive": "node test/comprehensive-test-runner.js",
    "test:all-fast": "node test/comprehensive-test-runner.js --fast",
    "test:watch": "karma start --auto-watch --no-single-run",
    "test:quality": "node test/code-quality-check.js",
    "test:live": "node test/live-console-testing.js",
    "test:ui": "npm run test:live",
    "test:manual": "npm run build && npm start",
    "test:lighthouse": "npm run start:test-server && npm run test:lighthouse:run && npm run stop:test-server",
    "test:lighthouse:run": "jest test/lighthouse-audit.test.js --testTimeout=120000",
    "test:web-vitals": "npm run start:test-server && npm run test:web-vitals:run && npm run stop:test-server",
    "test:web-vitals:run": "jest test/web-vitals.test.js --testTimeout=60000",
    "test:accessibility": "npm run start:test-server && npm run test:accessibility:run && npm run stop:test-server",
    "test:accessibility:run": "jest test/accessibility-compliance.test.js --testTimeout=60000",
    "test:security": "npm run start:test-server && npm run test:security:run && npm run stop:test-server",
    "test:security:run": "jest test/security-audit.test.js --testTimeout=60000",
    "test:performance": "npm run start:test-server && npm run test:performance:run && npm run stop:test-server",
    "test:performance:run": "jest test/performance-benchmarks.test.js --testTimeout=120000",
    "test:standards": "node test/web-standards-runner.js",
    "test:standards:ci": "npm run test:lighthouse && npm run test:web-vitals && npm run test:accessibility && npm run test:security && npm run test:performance",
    "test:all": "npm test && npm run test:standards",
    "test:production": "node test/production-readiness-suite.js",
    "test:production-ready": "npm run test:production",
    "test:interactive": "node test/interactive-console-test.js",
    "test:console": "node test/simple-console-monitor.js",
    "test:auto": "node test/automated-console-debug.js",
    "test:debug": "npm run test:auto",
    "prepare": "husky install",
    "start:test-server": "node test/test-server.js &",
    "stop:test-server": "pkill -f 'node test/test-server.js' || true",
    "deploy": "npm run build:production && npm run deploy:gh-pages",
    "deploy:gh-pages": "gh-pages -d dist"
  },
  "dependencies": {
    "three": "^0.164.1"
  },
  "devDependencies": {
    "@babel/core": "^7.24.5",
    "@babel/preset-env": "^7.24.5",
    "axe-core": "^4.8.3",
    "babel-loader": "^9.1.3",
    "chrome-launcher": "^1.1.0",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^7.1.2",
    "express": "^5.1.0",
    "html-webpack-plugin": "^5.6.0",
    "husky": "^8.0.3",
    "jasmine-core": "^5.1.2",
    "jest": "^29.7.0",
    "jest-html-reporters": "^3.1.7",
    "karma": "^6.4.3",
    "karma-chrome-launcher": "^3.2.0",
    "karma-jasmine": "^5.1.0",
    "karma-webpack": "^5.0.1",
    "lighthouse": "^11.4.0",
    "puppeteer": "^24.22.3",
    "serve": "^14.2.3",
    "style-loader": "^4.0.0",
    "webpack": "^5.91.0",
    "webpack-bundle-analyzer": "^4.10.2",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.0.4",
    "webpack-merge": "^6.0.1"
  }
}
